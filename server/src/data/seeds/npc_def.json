  "talk_trees": [
    {
      "id": "talk-guide",
      "name": "引路童子对话",
      "greeting_lines": [
        "欢迎来到青云村！修行之路漫漫，先从认识这里开始吧。",
        "你若有疑问，尽管问我。"
      ],
      "enabled": true,
      "sort_weight": 100,
      "version": 1
    },
    {
      "id": "talk-village-elder",
      "name": "村长对话",
      "greeting_lines": [
        "你来了。青云村虽小，却也暗流涌动。",
        "若想在这世道立足，先练胆，再练心。"
      ],
      "enabled": true,
      "sort_weight": 90,
      "version": 1
    },
    {
      "id": "talk-yaowang-elder",
      "name": "药王谷长老对话",
      "greeting_lines": [
        "心魔不只在敌人身上，也在你的念头里。",
        "先稳心，再谈突破。"
      ],
      "enabled": true,
      "sort_weight": 230,
      "version": 1
    },
    {
      "id": "talk-lingyao-merchant",
      "name": "灵药商人对话",
      "greeting_lines": [
        "药材讲究时机，错过一炷香就可能失灵。",
        "你若要配丹，我这里有最稳的方子。"
      ],
      "enabled": true,
      "sort_weight": 220,
      "version": 1
    },
    {
      "id": "talk-youming-guardian",
      "name": "幽冥守墓人对话",
      "greeting_lines": [
        "想入心魔幻境，先问问自己的道心够不够稳。",
        "退一步是活路，进一步是成道。"
      ],
      "enabled": true,
      "sort_weight": 230,
      "version": 1
    },
    {
      "id": "talk-anshi-merchant",
      "name": "暗市商人对话",
      "greeting_lines": [
        "这里不问来路，只看你付不付得起代价。",
        "稀有货只卖有准备的人。"
      ],
      "enabled": true,
      "sort_weight": 220,
      "version": 1
    },
    {
      "id": "talk-nanhai-merchant",
      "name": "南海商人对话",
      "greeting_lines": [
        "海路风险大，货也值钱。",
        "要走矿渊线，记得带足补给。"
      ],
      "enabled": true,
      "sort_weight": 220,
      "version": 1
    },
    {
      "id": "talk-kuangmai-explorer",
      "name": "矿脉探索者对话",
      "greeting_lines": [
        "矿渊每天都在变化，别轻信旧地图。",
        "跟紧我，能少走很多弯路。"
      ],
      "enabled": true,
      "sort_weight": 230,
      "version": 1
    },
    {
      "id": "talk-yanbing-watcher",
      "name": "炎冰巡守对话",
      "greeting_lines": [
        "裂谷的潮汐比矿渊更凶，先稳住气机再深入。",
        "炎霜裂渊每次开启都不同，别把上次经验当真理。"
      ],
      "enabled": true,
      "sort_weight": 235,
      "version": 1
    },
    {
      "id": "talk-taixi-warden",
      "name": "镇沼使对话",
      "greeting_lines": [
        "胎息先稳，方可结胎。",
        "阵线我来守，你专注修行。"
      ],
      "enabled": true,
      "sort_weight": 80,
      "version": 1
    },
    {
      "id": "talk-taixi-apothecary",
      "name": "胎息药师对话",
      "greeting_lines": [
        "丹药可稳压，不能替你守心。",
        "采药后段最忌心浮气躁。"
      ],
      "enabled": true,
      "sort_weight": 79,
      "version": 1
    },
    {
      "id": "talk-jiutai-hermit",
      "name": "九台隐修者对话",
      "greeting_lines": [
        "九台只看结果，不听借口。",
        "你若能守住阵心，结胎只是开始。"
      ],
      "enabled": true,
      "sort_weight": 78,
      "version": 1
    },
    {
      "id": "talk-jiutai-broker",
      "name": "九台行商对话",
      "greeting_lines": [
        "宫阙里什么都贵，但都值。",
        "想快一步，就得舍得投资源。"
      ],
      "enabled": true,
      "sort_weight": 77,
      "version": 1
    }
  ]
