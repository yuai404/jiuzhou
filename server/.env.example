# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jiuzhou
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_LOG=false

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# 服务器配置
HOST=0.0.0.0
PORT=6011
NODE_ENV=development

# 跨域配置
CORS_ORIGIN="http://localhost:6010"

# 启动与系统配置
# 未配置时默认使用 CPU 核数 - 1（最少 1）
IDLE_WORKER_COUNT=1
# 挂机战斗批次定时清理：是否启用（默认 true）
IDLE_BATCH_CLEANUP_ENABLED=true
# 挂机战斗批次保留天数（默认 7）
IDLE_BATCH_RETENTION_DAYS=7
# 定时清理执行间隔（秒，默认 600）
IDLE_BATCH_CLEANUP_INTERVAL_SECONDS=600
# 单批删除条数（默认 5000）
IDLE_BATCH_CLEANUP_DELETE_BATCH_SIZE=5000
# 单轮最多删除批次数（默认 20）
IDLE_BATCH_CLEANUP_MAX_BATCHES_PER_RUN=20
# 游戏内时间流速倍率（默认 60）
GAME_TIME_SCALE=60

# 角色体力恢复配置
STAMINA_MAX=100
STAMINA_RECOVER_PER_TICK=1
STAMINA_RECOVER_INTERVAL_SEC=300

# 境界配置文件路径（可选；不填则按内置路径顺序查找）
REALM_CONFIG_PATH=""

# 一次性脚本开关（仅在需要清空头像时设为 1）
# CLEAR_AVATARS=1

# 腾讯云 COS 配置（头像上传）
# 未配置时自动回退本地磁盘存储
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION="ap-guangzhou"
COS_AVATAR_PREFIX="avatars/"
# 自定义域名（不含协议和末尾 /），例如 oss.example.com
# 配置后头像 URL 会使用此域名，未配置则使用 COS 默认域名
COS_DOMAIN=""


AI_TECHNIQUE_MODEL_URL=
AI_TECHNIQUE_MODEL_KEY=
AI_TECHNIQUE_MODEL_NAME=

# AI 招式图片生成（可选；不配置则自动回退默认图标）
# provider:
# - auto: 自动识别（模型名是 qwen-image-* 或 URL 含 dashscope 时走千问专用接口）
# - dashscope: 强制走千问专用文生图接口
# - openai: 强制走 OpenAI 兼容接口
AI_TECHNIQUE_IMAGE_PROVIDER=auto
# 千问推荐填基础地址（会自动补全为 /api/v1/services/aigc/multimodal-generation/generation）：
# AI_TECHNIQUE_IMAGE_MODEL_URL=https://dashscope.aliyuncs.com
# OpenAI 兼容可填基础地址（如 https://api.openai.com）或完整地址（.../v1/images/generations）
AI_TECHNIQUE_IMAGE_MODEL_URL=
AI_TECHNIQUE_IMAGE_MODEL_KEY=
AI_TECHNIQUE_IMAGE_MODEL_NAME=qwen-image-2.0
AI_TECHNIQUE_IMAGE_SIZE=512x512
# 默认 b64_json；若服务商不支持会自动回退到不带 response_format 的请求
AI_TECHNIQUE_IMAGE_RESPONSE_FORMAT=b64_json
AI_TECHNIQUE_IMAGE_TIMEOUT_MS=15000
# 单次最多为多少个技能生成图片（建议 <= 4）
AI_TECHNIQUE_IMAGE_MAX_SKILLS=4
# 是否打印图片生成调试日志（true/false）
AI_TECHNIQUE_IMAGE_DEBUG=false
