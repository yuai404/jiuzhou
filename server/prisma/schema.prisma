/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model arena_battle {
  battle_id                                                   String     @id @db.VarChar(128)
  challenger_character_id                                     Int
  opponent_character_id                                       Int
  status                                                      String     @default("running") @db.VarChar(16)
  result                                                      String?    @db.VarChar(16)
  delta_score                                                 Int        @default(0)
  score_before                                                Int?
  score_after                                                 Int?
  created_at                                                  DateTime   @default(now()) @db.Timestamptz(6)
  finished_at                                                 DateTime?  @db.Timestamptz(6)
  characters_arena_battle_challenger_character_idTocharacters characters @relation("arena_battle_challenger_character_idTocharacters", fields: [challenger_character_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  characters_arena_battle_opponent_character_idTocharacters   characters @relation("arena_battle_opponent_character_idTocharacters", fields: [opponent_character_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([challenger_character_id, created_at(sort: Desc)], map: "idx_arena_battle_challenger_time")
  @@index([opponent_character_id, created_at(sort: Desc)], map: "idx_arena_battle_opponent_time")
  @@index([status, created_at(sort: Desc)], map: "idx_arena_battle_status_time")
}

