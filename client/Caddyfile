{$DOMAIN:localhost} {
    # Gzip compression
    encode gzip

    # API proxy - must be before file_server to take priority
    handle /api/* {
        reverse_proxy {$API_HOST:server:6011}
    }

    # WebSocket proxy for game socket
    handle /game-socket/* {
        reverse_proxy {$API_HOST:server:6011}
    }

    # WebSocket proxy for socket.io (fallback)
    handle /socket.io/* {
        reverse_proxy {$API_HOST:server:6011}
    }

    # Static files and SPA routing for everything else
    handle {
        root * /srv

        # Cache static assets
        @static {
            path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2
        }
        header @static Cache-Control "public, max-age=31536000, immutable"

        # SPA routing - fallback to index.html
        try_files {path} /index.html
        file_server
    }
}
